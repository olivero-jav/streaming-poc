# URL base del backend
BASE_URL=http://localhost:8080

# Carga: virtual users y duracion
VUS=10
DURATION=15m

# IDs requeridos segun el script que corras
VIDEO_ID=
STREAM_ID=

# Salida HTML/JSON del k6-reporter (opcional). run.ps1 define REPORT_DIR al directorio reports de testing.
# Si corres `k6 run testing/....js` desde la raíz del repo, usa: REPORT_DIR=testing/reports
# REPORT_DIR=testing/reports

# Thresholds (opcional, tiene defaults en cada script)
# THRESHOLD_FAILED=rate<0.01
# THRESHOLD_P95=p(95)<400
# THRESHOLD_P95_PLAYLIST=p(95)<400
